# ─────────────────────────────────────────────────────
# Evergreen Preschool — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────

# Site URL (used for metadata and sitemaps)
NEXT_PUBLIC_SITE_URL=https://evergreenpreschool.com

# Contact form — Formspree endpoint (https://formspree.io)
# Replace with your own Formspree form ID
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel (set these as GitHub repo secrets, NOT here)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
